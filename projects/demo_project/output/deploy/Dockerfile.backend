FROM node:18-alpine

WORKDIR /app

# 安装系统依赖 (用于 pdfkit 和 qrcode)
RUN apk add --no-cache \
    fontconfig \
    freetype \
    cairo \
    pango \
    jpeg \
    giflib

# 复制后端代码
COPY backend/package*.json ./
RUN npm install --production

COPY backend/ ./

# 暴露端口
EXPOSE 3000

# 启动命令
CMD ["npm", "start"]
