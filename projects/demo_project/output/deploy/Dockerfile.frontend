FROM node:18-alpine AS builder

WORKDIR /app

# 复制前端代码
COPY frontend/package*.json ./
RUN npm install

COPY frontend/ ./

# 构建前端
RUN npm run build

# 生产阶段
FROM nginx:alpine

# 复制构建产物到 nginx
COPY --from=builder /app/dist /usr/share/nginx/html

# 复制 nginx 配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
